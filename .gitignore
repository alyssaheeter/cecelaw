# =============================================================================
# CECE LAW EVIDENCE MANAGER — .gitignore
# =============================================================================

# Dependencies
node_modules/
.npm

# Build outputs
dist/
.next/
out/
build/
*.tsbuildinfo

# Environment files — NEVER commit these
.env
.env.local
.env.*.local
.env.development
.env.production

# Database files
*.db
*.db-journal
*.db-wal
*.db-shm

# Evidence storage (local files — never in git)
/data/

# Model files (large binary downloads)
*.bin
*.gguf
*.pt
*.onnx
/models/

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Test coverage
coverage/
.nyc_output/

# IDE
.vscode/settings.json
.idea/

# Temporary
*.tgz
*.pid
*.seed

# Firebase / GCP (legacy — kept only in _archive/)
.firebase/
.firebaserc
firebase.json
firestore.rules
firestore.indexes.json
apphosting.yaml

# ESLint cache
.eslintcache
