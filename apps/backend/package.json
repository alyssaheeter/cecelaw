{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify REST API — business logic, auth, chain-of-custody, job dispatch",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src",
    "seed": "ts-node scripts/seed-demo.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@cece/domain": "*",
    "@cece/config": "*",
    "@cece/analysis": "*",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@prisma/client": "^5.20.0",
    "@sinclair/typebox": "^0.33.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "fastify": "^4.28.1",
    "archiver": "^7.0.1",
    "csv-writer": "^1.6.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/archiver": "^6.0.2",
    "@types/node": "^20.17.0",
    "prisma": "^5.20.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0"
  }
}
