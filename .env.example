# =============================================================================
# CECE LAW EVIDENCE MANAGER — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# All variables are required unless marked [OPTIONAL].
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# Path to the local SQLite database file.
# Will be created on first run if it does not exist.
# -----------------------------------------------------------------------------
DATABASE_URL="file:./data/evidence.db"

# -----------------------------------------------------------------------------
# EVIDENCE STORAGE
# Absolute path to the root directory where evidence files are stored.
# The backend will create this directory on first run if it does not exist.
# Structure: EVIDENCE_ROOT/<matter_id>/<evidence_id>/<filename>
# -----------------------------------------------------------------------------
EVIDENCE_ROOT="/path/to/your/evidence-storage"

# -----------------------------------------------------------------------------
# SERVER
# Port the Fastify backend API listens on.
# The Next.js web app runs on port 3000 by default.
# -----------------------------------------------------------------------------
PORT=3001

# -----------------------------------------------------------------------------
# AUTHENTICATION
# Secret key for signing JWT tokens.
# MUST be at least 32 characters long.
# Generate a secure value with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET="replace-this-with-a-secure-random-string-at-least-32-chars"

# JWT expiry duration (e.g. "8h", "1d", "7d")
JWT_EXPIRY="8h"

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV="development"

# -----------------------------------------------------------------------------
# WHISPER ASR MODEL
# Model size to use for local transcription.
# Options: tiny | small | medium | large
# Default: small (good balance of speed and accuracy)
# Larger models are more accurate but significantly slower on CPU.
# Run scripts/download-models.sh to download the model files.
# -----------------------------------------------------------------------------
WHISPER_MODEL="small"

# [OPTIONAL] Override path to the whisper.cpp binary.
# If not set, the bundled nodejs-whisper binary is used.
# WHISPER_BINARY_PATH="/usr/local/bin/whisper"

# -----------------------------------------------------------------------------
# FFMPEG
# [OPTIONAL] Override path to the ffmpeg binary.
# If not set, the bundled ffmpeg-static binary is used.
# FFMPEG_BINARY_PATH="/usr/local/bin/ffmpeg"
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# NEXT.JS PUBLIC VARS
# Must be prefixed with NEXT_PUBLIC_ to be available in the browser.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3001"
