{
  "name": "@cece/domain",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript interfaces, enums, and Zod validation schemas for Cece Law Evidence Manager",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0"
  }
}
